{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blockhaus",
  "version": "0.1.0",
  "identifier": "com.vijesh.blockhaus",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Blockhaus",
        "width": 960,
        "height": 720,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
